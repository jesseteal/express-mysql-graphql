{
  "name": "@jesseteal/express-mysql-graphql",
  "version": "2.0.4",
  "description": "Instant graphql endpoint for express / mysql",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.2.2",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jesseteal/express-mysql-graphql"
  },
  "keywords": [
    "express",
    "mysql",
    "graphql"
  ],
  "author": "Jesse Teal",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm test && pnpm run build",
    "test": "jest"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.33",
    "express": "^4.22.2",
    "express-jwt": "^7.7.8",
    "graphql": "^16.14.0",
    "graphql-scalars": "^1.25.0",
    "graphql-yoga": "^3.9.1",
    "mysql2": "3.12.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^18.19.130",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "^4.9.5"
  }
}
